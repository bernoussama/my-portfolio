---
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
import '../../style.css';
---

<!doctype html>
<html lang="en" data-theme="dark">

<head>
	<title>Oussama Bernou | Full-Stack Engineer</title>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<meta name="description" content="Portfolio of Oussama Bernou, a full-stack engineer focused on product engineering, AI-powered tooling, and backend systems." />
	<meta name="color-scheme" content="dark light" />
	<script is:inline>
		(() => {
			try {
				const storedTheme = localStorage.getItem('theme');
				const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				document.documentElement.dataset.theme = storedTheme === 'light' || storedTheme === 'dark'
					? storedTheme
					: prefersDark
						? 'dark'
						: 'light';
			} catch {
				document.documentElement.dataset.theme = 'dark';
			}
		})();
	</script>
	<link rel="preload" href="/fonts/inter/inter-latin-400.woff2" as="font" type="font/woff2" crossorigin />
	<link rel="icon" href="/images/favicon.png">
</head>

<body class="bg-surface font-sans text-on-surface antialiased overflow-x-hidden">
	<div class="flex min-h-screen flex-col">
		<NavBar />
		<main class="flex-1">
			<slot />
		</main>
		<Footer />
	</div>

	<script is:inline>
		(() => {
			if (typeof window === 'undefined') return;
			const w = window;

			const initTechBadges = () => {
				if (!('IntersectionObserver' in w)) {
					document.querySelectorAll('.tech-badge[data-animate]')
						.forEach((el) => el.classList.add('is-visible'));
					return;
				}

				if (!w.__techBadgeIO) {
					w.__techBadgeIO = new IntersectionObserver((entries) => {
						for (const entry of entries) {
							if (entry.isIntersecting) {
								const el = entry.target;
								const delay = el.getAttribute('data-delay') || Math.floor(Math.random() * 220);
								el.style.setProperty('--reveal-delay', `${delay}ms`);
								el.classList.add('is-visible');
								w.__techBadgeIO.unobserve(el);
							}
						}
					}, { threshold: 0.15, rootMargin: '0px 0px -10% 0px' });
				}

				document.querySelectorAll('.tech-badge[data-animate]')
					.forEach((el) => w.__techBadgeIO.observe(el));
			};

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', initTechBadges);
			} else {
				initTechBadges();
			}
		})();
	</script>

	<style is:global>
		.prose :where(code):not(:where([class~='not-prose'], [class~='not-prose'] *))::before,
		.prose :where(code):not(:where([class~='not-prose'], [class~='not-prose'] *))::after {
			content: none !important;
		}

		.prose pre.astro-code code {
			background-color: transparent !important;
			border-radius: 0 !important;
			padding: 0 !important;
			font-weight: inherit !important;
			font-size: inherit !important;
			font-family: inherit !important;
			color: inherit !important;
		}

		.prose pre.astro-code {
			border-radius: 0 !important;
			border: 1px solid rgb(var(--color-grid-border)) !important;
			border-left: 2px solid rgb(var(--color-on-surface-variant)) !important;
		}

		/* Only recolor blocks that ship both light and dark shiki themes. */
		[data-theme='light'] .prose pre.astro-code.astro-code-themes {
			background-color: rgb(var(--color-surface-lowest)) !important;
		}

		[data-theme='dark'] .prose pre.astro-code.astro-code-themes,
		[data-theme='dark'] .prose pre.astro-code.astro-code-themes span {
			color: var(--shiki-dark) !important;
			background-color: var(--shiki-dark-bg) !important;
			font-style: var(--shiki-dark-font-style) !important;
			font-weight: var(--shiki-dark-font-weight) !important;
			text-decoration: var(--shiki-dark-text-decoration) !important;
		}
	</style>
</body>

</html>
