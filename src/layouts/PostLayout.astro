---
import Layout from './Layout.astro';
import PageViews from '../components/PageViews.astro';
const {frontmatter} = Astro.props;
const pageUrl = new URL(Astro.url.pathname, Astro.url.origin).href;
const formattedDate = new Date(frontmatter.pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---
<Layout>
  <section class="grid-border-b">
    <div class="py-8 px-6 md:py-16 md:px-12 max-w-4xl mx-auto">
      <a href="/blog" class="font-mono text-[10px] uppercase tracking-[0.2em] text-on-surface-variant hover:text-primary inline-flex items-center gap-2 mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Back to Writing
      </a>
      <h1 class="text-3xl md:text-5xl font-black tracking-tight-display leading-tight">{frontmatter.title}</h1>
      <div class="mt-4 flex items-center gap-4">
        <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-on-surface-variant">{formattedDate}</span>
        <span class="text-on-surface-variant">|</span>
        <PageViews url={pageUrl} />
      </div>
      <p class="mt-4 text-on-surface-variant">{frontmatter.description}</p>
    </div>
  </section>
  <article class="post-article-surface max-w-4xl mx-auto px-6 md:px-12 py-12">
    <div class="post-content prose max-w-none prose-headings:font-black prose-headings:uppercase prose-headings:tracking-tight-display prose-headings:text-on-surface prose-p:text-on-surface-variant prose-strong:text-on-surface prose-li:text-on-surface-variant prose-blockquote:text-on-surface-variant prose-code:text-on-surface prose-code:bg-surface-lowest prose-code:px-1 prose-code:py-0.5 prose-code:rounded-sm prose-hr:border-outline-variant prose-th:text-on-surface prose-td:text-on-surface-variant">
      <slot />
    </div>
  </article>
</Layout>

<style is:global>
  .post-content :where(a):not(:where([class~='not-prose'], [class~='not-prose'] *)) {
    color: rgb(var(--color-fg));
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: rgb(var(--color-primary) / 0.6);
    text-underline-offset: 4px;
  }

  .post-content :where(a:hover):not(:where([class~='not-prose'], [class~='not-prose'] *)) {
    color: rgb(var(--color-primary));
    text-decoration-color: rgb(var(--color-primary));
  }
</style>
