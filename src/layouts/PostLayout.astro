---
import Layout from './Layout.astro';
import PageViews from '../components/PageViews.astro';
const {frontmatter} = Astro.props;
const pageUrl = new URL(Astro.url.pathname, Astro.url.origin).href;
const formattedDate = new Date(frontmatter.pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---
<Layout>
  <section class="grid-border-b">
    <div class="py-8 px-6 md:py-16 md:px-12 max-w-4xl mx-auto">
      <a href="/blog" class="font-mono text-[10px] uppercase tracking-[0.2em] text-on-surface-variant hover:text-primary transition-colors inline-flex items-center gap-2 mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Back to Writing
      </a>
      <h1 class="text-3xl md:text-5xl font-black tracking-tight-display leading-tight">{frontmatter.title}</h1>
      <div class="mt-4 flex items-center gap-4">
        <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-on-surface-variant/60">{formattedDate}</span>
        <span class="text-on-surface-variant/20">|</span>
        <PageViews url={pageUrl} />
      </div>
      <p class="mt-4 text-on-surface-variant">{frontmatter.description}</p>
    </div>
  </section>
  <article class="max-w-4xl mx-auto px-6 md:px-12 py-12">
    <div class="prose max-w-none prose-invert prose-headings:font-black prose-headings:uppercase prose-headings:tracking-tight-display prose-headings:text-on-surface prose-p:text-on-surface-variant prose-a:text-primary prose-code:bg-surface-lowest prose-code:px-1 prose-code:py-0.5 prose-code:rounded-sm prose-pre:bg-surface-highest prose-pre:border-l-2 prose-pre:border-primary">
      <slot />
    </div>
  </article>
</Layout>
