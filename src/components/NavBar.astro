---
import Nav from './Nav.astro';
const { pathname } = Astro.url;
const navLinks = [
	{ href: '/projects', label: 'Projects' },
	{ href: '/blog', label: 'Writing' },
	{ href: '/resume', label: 'Resume' },
	{ href: '/freelance', label: 'Freelance' },
];
---

<header class="grid grid-cols-12 w-full grid-border-b sticky top-0 z-50 bg-surface-highest/60 backdrop-blur-[24px]">
	<div class="col-span-8 md:col-span-2 p-4 md:p-6 flex items-center md:justify-center grid-border-r">
		<a href="/" class="font-black text-xl md:text-2xl tracking-tighter text-on-surface hover:text-primary transition-colors">
			OB—01
		</a>
	</div>
	<nav class="hidden md:flex col-span-8 justify-between items-center px-8 lg:px-12 uppercase text-xs font-bold tracking-widest">
		{navLinks.map((link) => (
			<a
				class={`hover:text-primary transition-colors ${pathname === link.href ? 'text-primary' : 'text-on-surface-variant'}`}
				href={link.href}
			>
				{link.label}
			</a>
		))}
	</nav>
	<div class="col-span-4 md:col-span-2 flex items-center justify-end md:justify-stretch min-h-[4.5rem] md:min-h-0">
		<a
			href="mailto:contact@bernoussama.com"
			class="hidden md:flex w-full min-h-[4.5rem] md:min-h-0 md:h-full bg-primary hover:bg-primary-dim text-on-primary font-bold text-xs uppercase tracking-widest py-6 items-center justify-center transition-colors"
		>
			Connect
		</a>
		<button id="mobile-menu-toggle" type="button" class="md:hidden p-4 text-on-surface-variant hover:text-primary transition-colors" aria-label="Open menu">
			<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<line x1="4" x2="20" y1="6" y2="6"></line>
				<line x1="4" x2="20" y1="12" y2="12"></line>
				<line x1="4" x2="20" y1="18" y2="18"></line>
			</svg>
		</button>
	</div>
</header>

<div id="mobile-menu" class="fixed inset-0 z-[100] bg-surface/95 backdrop-blur-xl hidden flex-col">
	<div class="flex justify-between items-center p-6 grid-border-b">
		<span class="font-black text-2xl tracking-tighter">OB—01</span>
		<button id="mobile-menu-close" class="text-on-surface-variant hover:text-primary transition-colors">
			<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<line x1="18" y1="6" x2="6" y2="18"></line>
				<line x1="6" y1="6" x2="18" y2="18"></line>
			</svg>
		</button>
	</div>
	<nav class="flex flex-col p-6 gap-6">
		{navLinks.map((link) => (
			<a
				href={link.href}
				class="text-2xl font-black uppercase tracking-tighter hover:text-primary transition-colors"
			>
				{link.label}
			</a>
		))}
		<a href="mailto:contact@bernoussama.com" class="text-2xl font-black uppercase tracking-tighter text-primary hover:text-primary-dim transition-colors">
			Connect
		</a>
	</nav>
	<div class="mt-auto p-6 grid-border-t">
		<Nav />
	</div>
</div>

<script is:inline>
	(() => {
		const toggle = document.getElementById('mobile-menu-toggle');
		const menu = document.getElementById('mobile-menu');
		const close = document.getElementById('mobile-menu-close');
		if (!toggle || !menu || !close) return;
		toggle.addEventListener('click', () => {
			menu.classList.remove('hidden');
			menu.classList.add('flex');
		});
		close.addEventListener('click', () => {
			menu.classList.add('hidden');
			menu.classList.remove('flex');
		});
		menu.querySelectorAll('a').forEach((a) => {
			a.addEventListener('click', () => {
				menu.classList.add('hidden');
				menu.classList.remove('flex');
			});
		});
	})();
</script>
