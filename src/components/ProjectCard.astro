---
interface Props {
	src?: string;
	title: string;
	body?: string;
	href?: string;
	demoUrl?: string;
	techs?: Array<string>;
	buttonText?: string;
	projectPage?: string;
	actions?: Array<{
		label: string;
		href: string;
		external?: boolean;
		variant?: 'primary' | 'default';
	}>;
	statusLabel?: string;
	index?: number;
}

	const { src, title, href, body, demoUrl, techs, buttonText, projectPage, actions, statusLabel, index = 0 }: Props = Astro.props;

	const validHref = href && href !== '#' ? href : undefined;
	const validDemoUrl = demoUrl && demoUrl !== '#' ? demoUrl : undefined;

	const fallbackActions: NonNullable<Props['actions']> = [];

	if (projectPage) {
		if (validDemoUrl) {
			fallbackActions.push({ label: 'Live Demo', href: validDemoUrl, external: true, variant: 'primary' });
		}
		if (validHref) {
			fallbackActions.push({ label: 'GitHub', href: validHref, external: true, variant: 'default' });
		}
		fallbackActions.push({ label: buttonText ? buttonText : 'Details', href: projectPage, external: false, variant: 'primary' });
	} else {
		if (validDemoUrl) {
			fallbackActions.push({ label: 'Live Demo', href: validDemoUrl, external: true, variant: 'primary' });
		}
		if (validHref) {
			fallbackActions.push({
				label: validDemoUrl ? 'GitHub' : buttonText ? buttonText : 'Source',
				href: validHref,
				external: true,
				variant: validDemoUrl ? 'default' : 'primary',
			});
		}
	}

	const normalizedActions = actions ?? fallbackActions;
---
<article class="relative group hover:bg-surface-high grid-border-b">
	<span class="absolute top-6 right-6 font-mono text-[10px] text-on-surface-variant border border-outline-variant/30 px-2 py-0.5">{String(index + 1).padStart(2, '0')}</span>
	{src ? (
		<div class="overflow-hidden md:h-[280px] max-sm:h-[200px] bg-surface-lowest">
			<img src={src} class="w-full h-full object-cover opacity-70 group-hover:opacity-90 transition-opacity duration-300" loading="lazy" alt={title} />
		</div>
	) : null}
	<div class="p-8 md:p-10">
		<h3 class="text-2xl md:text-3xl font-black uppercase tracking-tighter mb-4">{title}</h3>
		<p class="text-on-surface-variant mb-6 max-w-md leading-relaxed text-sm">{body}</p>
		{techs && (
			<div class="flex flex-wrap gap-2 mb-6">
				{techs.map((tech) => (
					<span class="font-mono text-[10px] border border-outline-variant/30 px-2 py-1 uppercase tracking-[0.15em] text-on-surface-variant">{tech}</span>
				))}
			</div>
		)}
		{statusLabel && <p class="font-mono text-[10px] text-on-surface-variant uppercase tracking-widest">{statusLabel}</p>}
		{normalizedActions.length > 0 && (
			<div class="flex flex-wrap gap-3 mt-4">
				{normalizedActions.map((action) => (
					<a
						href={action.href}
						target={action.external ? '_blank' : undefined}
						rel={action.external ? 'noreferrer' : undefined}
						class={action.variant === 'default'
							? 'border border-primary/40 text-primary font-mono text-[10px] uppercase tracking-widest px-4 py-2 hover:bg-primary hover:text-on-primary'
							: 'bg-primary text-on-primary font-mono text-[10px] uppercase tracking-widest px-4 py-2 hover:bg-primary-dim'}
					>
						{action.label}
					</a>
				))}
			</div>
		)}
	</div>
</article>
