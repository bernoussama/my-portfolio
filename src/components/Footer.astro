---
const currentYear = new Date().getFullYear();
---
<footer class="grid-border-t bg-surface-lowest">
	<div class="container mx-auto px-6 md:px-12 py-10 md:py-12 flex flex-col md:flex-row justify-between items-end gap-8 md:gap-10">
		<div class="flex flex-col gap-6">
			<h2 class="text-5xl lg:text-7xl font-black uppercase tracking-tighter leading-none">Oussama Bernou</h2>
			<nav class="flex flex-wrap gap-8 font-mono text-[10px] uppercase tracking-[0.2em] text-on-surface-variant">
				<a class="hover:text-on-surface transition-colors" href="https://x.com/bernoussama">X.com</a>
				<a class="hover:text-on-surface transition-colors" href="https://github.com/bernoussama">Github</a>
				<a class="hover:text-on-surface transition-colors" href="https://linkedin.com/in/oussama-bernou">Linkedin</a>
			</nav>
		</div>
		<div class="text-left md:text-right font-mono text-[9px] uppercase tracking-widest text-on-surface-variant/50 leading-relaxed">
			<p>© {currentYear} / Designed with brutalist principles</p>
			<p>Built with Astro & Tailwind / Deployed on Cloudflare</p>
		</div>
	</div>
</footer>
