---
const { url, title, description, pubDate } = Astro.props;
const formattedDate = pubDate ? new Date(pubDate).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
}) : null;
---
<a href={url} class="block w-full p-6 grid-border-b hover:bg-surface-high transition-colors group">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
        <div class="flex-1">
            <h5 class="text-lg font-bold tracking-tight group-hover:text-primary transition-colors">{title}</h5>
            {formattedDate && (
                <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-on-surface-variant/60">{formattedDate}</span>
            )}
        </div>
        <svg class="w-5 h-5 text-on-surface-variant/40 group-hover:text-primary group-hover:translate-x-1 transition-all flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
    </div>
    <p class="mt-3 text-sm text-on-surface-variant leading-relaxed">{description}</p>
</a>
