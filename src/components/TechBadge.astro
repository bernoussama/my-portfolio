---
interface Props {
	iconLink?: string,
	name: string
}
const { iconLink, name } = Astro.props
---
<span class="tech-badge px-2.5 py-1 text-on-surface-variant text-[10px] font-mono font-medium uppercase tracking-[0.15em] bg-surface-highest border border-outline-variant/20 inline-flex items-center gap-1" data-animate="true">
	{iconLink && (
		<img src={iconLink} title={name} alt={name} width="16" height="16" />
	)}
	<span>{name}</span>
</span>

<style>
	.tech-badge {
		opacity: 0;
		transform: translateY(4px);
		transition: opacity 400ms ease, transform 400ms ease;
		transition-delay: var(--reveal-delay, 0ms);
	}
	.tech-badge.is-visible {
		opacity: 1;
		transform: translateY(0);
	}
	@media (prefers-reduced-motion: reduce) {
		.tech-badge { transition: none; transform: none; }
	}
</style>
