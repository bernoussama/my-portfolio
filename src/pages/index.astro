---
import Layout from '../layouts/Layout.astro';
import HeroBackground from '../components/HeroBackground.astro';
import ProjectCard from '../components/ProjectCard.astro';
import BlogPost from '../components/BlogPost.astro';
import TechBadge from '../components/TechBadge.astro';
import { featuredProjects } from '../data/projects';

const strengthGroups = [
	{
		title: "Full-stack product development",
		description: "Shipping practical software across the frontend, backend, and data flow instead of treating them as separate concerns.",
		items: ['TypeScript', 'React', 'Node.js', 'Remix', 'Tailwind'],
	},
	{
		title: 'AI integrations and workflow tooling',
		description: 'Using LLM APIs and automation patterns to make real workflows faster for developers and teams.',
		items: ['LLM Integrations', 'Gemini API', 'CLI Tooling', 'Automation'],
	},
	{
		title: 'Backend and systems engineering',
		description: 'Building APIs and low-level services with enough systems depth to reason about networking, performance, and reliability.',
		items: ['Go', 'Rust', 'Hono', 'REST APIs', 'Linux'],
	},
	{
		title: 'Data and platform fundamentals',
		description: 'Working comfortably with application data, deployment-minded architectures, and the operational details behind shipped software.',
		items: ['PostgreSQL', 'MySQL', 'MongoDB', 'PocketBase'],
	},
];

const featuredWriting = [
	{
		url: '/blog/go-embed',
		title: 'How to Seamlessly Embed a Remix SPA into Your Go Backend',
		description: 'Embedding a Remix SPA in a Go Backend: A true Full-Stack Solution',
		pubDate: '2025-01-28',
	},
	{
		url: '/blog/rust-http-server-1',
		title: 'Rewriting a C HTTP Server in Rust from scratch - part 1',
		description: 'Building a Rust HTTP Server from a C Foundation',
		pubDate: '2025-03-09',
	},
	{
		url: '/blog/web-request-journey',
		title: 'The journey of an HTTP request',
		description: 'What happens when you type https://www.google.com and press enter?',
	},
];
---

<Layout>
	<main class="container">
		<div class="mx-auto max-w-7xl">
            <div class="mx-auto flex max-w-[980px] flex-col items-center gap-2 py-8 md:py-12 md:pb-8 lg:py-24 lg:pb-20">
                    <HeroBackground />
                <div class="relative w-full px-4 py-10 md:py-14 lg:py-20">
                    <div class="relative z-10 flex flex-col items-center gap-3">
                        <p class="text-center text-sm font-semibold uppercase tracking-[0.2em] text-muted-foreground">
                            Full-stack engineer
                        </p>
                        <h1 class="text-center text-3xl font-bold leading-tight tracking-tighter md:text-6xl lg:leading-[1.1]">
                            Full-stack engineer building AI-powered products, developer tools, and backend systems.
                        </h1>

                        <p class="text-center text-md sm:text-lg text-muted-foreground"
                            style="display: inline-block; vertical-align: top; text-decoration: inherit; max-width: 568px;">
              I work across React, TypeScript, Node.js, Go, and Rust to build software that is practical, fast, and grounded in real workflows, from web apps and APIs to CLI tools and network services.
                        </p>
                        <div class="flex w-full items-center justify-center space-x-4 py-4 md:pb-10">
					<a class="uk-button uk-button-primary gap-2" href="/projects">
						<svg width="16" height="16" viewBox="0 0 20 20" stroke="currentColor">
							<rect width="13" height="17" fill="none" x="3.5" y="1.5"></rect>
							<line fill="none" x1="6" y1="12.5" x2="12" y2="12.5"></line>
							<line fill="none" x1="6" y1="8.5" x2="14" y2="8.5"></line>
							<line fill="none" x1="6" y1="6.5" x2="14" y2="6.5"></line>
							<line fill="none" x1="6" y1="10.5" x2="14" y2="10.5"></line>
						</svg>
						View Projects
	                    </a>
	                    <a class="uk-button uk-button-default gap-2" href="/resume">
						<svg width="16" height="16" viewBox="0 0 20 20" stroke="currentColor">
                            <rect width="13" height="17" fill="none" x="3.5" y="1.5"></rect>
                            <line fill="none" x1="6" y1="12.5" x2="12" y2="12.5"></line>
                            <line fill="none" x1="6" y1="8.5" x2="14" y2="8.5"></line>
                            <line fill="none" x1="6" y1="6.5" x2="14" y2="6.5"></line>
                            <line fill="none" x1="6" y1="10.5" x2="14" y2="10.5"></line>
                        </svg>
						Read Resume
	                    </a>
	                    <a class="uk-button uk-button-default gap-2" href="mailto:contact@bernoussama.com">
						Contact Me
	                    </a>
                        </div>
                    </div>
                </div>
				<section class="mt-16 w-full px-4">
					<div class="flex flex-col items-center gap-3 text-center">
						<h2 class="text-2xl font-bold">What I&apos;m strongest at</h2>
						<p class="max-w-2xl text-muted-foreground">
							You should be able to map me quickly: I build full-stack products, integrate AI into practical workflows, and bring systems depth to application work.
						</p>
					</div>
					<div class="mt-8 grid gap-6 md:grid-cols-2">
						{strengthGroups.map((group) => (
							<div class="rounded-xl border border-border bg-card p-6 shadow-sm">
								<h3 class="text-lg font-semibold">{group.title}</h3>
								<p class="mt-2 text-sm text-muted-foreground">{group.description}</p>
								<div class="mt-4 flex flex-wrap gap-2">
									{group.items.map((item) => <TechBadge name={item} />)}
								</div>
							</div>
						))}
					</div>
				</section>
				<!-- Section -->
				<section class="flex w-full flex-col items-center gap-8 mt-16 px-4">
					<div class="flex flex-col items-center gap-3 text-center">
						<h2 class="text-2xl font-bold">Featured Projects</h2>
						<p class="max-w-2xl text-muted-foreground">
							The strongest signal for hiring is the work itself: product-focused projects first, then the systems work that makes those product decisions stronger.
						</p>
					</div>
					<div class="grid w-full md:grid-cols-2 grid-flow-row gap-8">
					{featuredProjects.map((project) => (
						<ProjectCard 
							src={project.src}
							title={project.title}
							body={project.body}
							techs={project.techs}
							projectPage={project.projectPage}
							actions={project.actions}
							statusLabel={project.statusLabel}
						/>
					))}
					</div>
					<a class="uk-button uk-button-default" href="/projects">See All Projects</a>
				</section>

				<section class="mt-16 w-full px-4">
					<div class="flex flex-col items-center gap-3 text-center">
						<h2 class="text-2xl font-bold">Selected Writing</h2>
						<p class="max-w-2xl text-muted-foreground">
							The blog is part of the hiring story too. It shows low-level curiosity, full-stack problem solving, and the ability to communicate engineering tradeoffs clearly.
						</p>
					</div>
					<div class="mt-8 grid gap-4">
						{featuredWriting.map((post) => (
							<BlogPost url={post.url} title={post.title} description={post.description} pubDate={post.pubDate} />
						))}
					</div>
					<div class="mt-4 flex justify-center">
						<a class="uk-button uk-button-default" href="/blog">Read More Writing</a>
					</div>
				</section>

				<section class="flex flex-col items-center gap-6 mt-16 px-4 text-center">
					<h2 class="text-2xl font-bold">Let&apos;s build something useful</h2>
					<p class="max-w-2xl text-muted-foreground">
						If you need someone who can own features across frontend, backend, automation, and the underlying engineering details, I&apos;d be glad to talk.
					</p>
					<div class="flex flex-wrap items-center justify-center gap-3">
						<a class="uk-button uk-button-primary gap-x-2" href="mailto:contact@bernoussama.com">Contact Me</a>
						<a class="uk-button uk-button-default gap-x-2" href="/resume">Read Resume</a>
					</div>
				</section>
			</div>
		</div>
	</main>
</Layout>
