---
import Layout from '../layouts/Layout.astro';
import HeroBackground from '../components/HeroBackground.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';

const engineeringNotes = [
	{
		href: '/blog/rust-http-server-1',
		title: 'Rewriting a C HTTP Server in Rust from scratch - part 1',
		description: 'Building a Rust HTTP server from a C foundation—protocol handling, safety, and performance.',
	},
	{
		href: '/blog/go-embed',
		title: 'How to Seamlessly Embed a Remix SPA into Your Go Backend',
		description: 'Single deployable full-stack app: Go backend serving a Remix SPA—Docker-friendly and production-shaped.',
	},
	{
		href: '/blog/web-request-journey',
		title: 'The journey of an HTTP request',
		description: 'From DNS and TCP to TLS and rendering—how a browser request actually moves through the stack.',
	},
];
---

<Layout>
	<main class="container">
		<div class="mx-auto max-w-7xl">
			<div class="mx-auto flex max-w-[980px] flex-col items-center gap-2 py-8 md:py-12 md:pb-8 lg:py-24 lg:pb-20">
				<HeroBackground />
				<div class="relative w-full px-4 py-10 md:py-14 lg:py-20">
					<div class="relative z-10 flex flex-col items-center gap-2">
						<h1 class="text-center text-3xl font-bold leading-tight tracking-tighter md:text-5xl lg:text-6xl lg:leading-[1.1]">
							Full-stack engineer building AI-powered products, developer tools, and backend systems.
						</h1>

						<p
							class="text-center text-md sm:text-lg text-muted-foreground"
							style="display: inline-block; vertical-align: top; text-decoration: inherit; max-width: 640px;"
						>
							I work across React, TypeScript, Node.js, Go, and Rust to build software that is practical, fast, and grounded in real workflows—from web apps and APIs to CLI tools and network services.
						</p>
						<div class="flex w-full flex-wrap items-center justify-center gap-3 py-4 md:pb-10">
							<a class="uk-button uk-button-primary gap-x-2" href="/projects">
								<svg width="16" height="16" viewBox="0 0 20 20" stroke="currentColor" fill="none">
									<rect width="13" height="17" x="3.5" y="1.5"></rect>
									<line x1="6" y1="12.5" x2="12" y2="12.5"></line>
									<line x1="6" y1="8.5" x2="14" y2="8.5"></line>
									<line x1="6" y1="6.5" x2="14" y2="6.5"></line>
									<line x1="6" y1="10.5" x2="14" y2="10.5"></line>
								</svg>
								View projects
							</a>
							<a class="uk-button uk-button-default gap-2" href="/resume">
								<svg width="16" height="16" viewBox="0 0 20 20" stroke="currentColor" fill="none">
									<rect width="13" height="17" x="3.5" y="1.5" rx="1"></rect>
									<line x1="6" y1="6.5" x2="14" y2="6.5"></line>
									<line x1="6" y1="8.5" x2="14" y2="8.5"></line>
									<line x1="6" y1="10.5" x2="12" y2="10.5"></line>
								</svg>
								Read resume
							</a>
							<a class="uk-button uk-button-default gap-2" href="mailto:contact@bernoussama.com" target="_blank">
								<svg width="16" height="16" fill="currentColor" viewBox="0 0 20 20">
									<polyline fill="none" stroke="currentColor" points="1.4,6.5 10,11 18.6,6.5"></polyline>
									<path d="M 1,4 1,16 19,16 19,4 1,4 Z M 18,15 2,15 2,5 18,5 18,15 Z"></path>
								</svg>
								Contact me
							</a>
						</div>
					</div>
				</div>

				<section class="flex w-full max-w-[720px] flex-col gap-3 px-4 text-center mt-4 md:mt-0">
					<p class="text-md sm:text-lg text-foreground">
						<strong class="font-semibold text-foreground">Why hire me?</strong> I ship production-shaped full-stack features—UI, APIs, data, and integrations—and I move quickly without sacrificing clarity. AI workflows, developer tooling, and automation are core strengths; systems work (HTTP, DNS, Rust/C) means I debug hard problems and design interfaces that behave well under load.
					</p>
				</section>

				<section class="flex w-full flex-col items-center gap-8 mt-16 px-4">
					<h2 class="text-2xl font-bold">Featured projects</h2>
					<p class="text-center text-muted-foreground max-w-2xl">
						Product and full-stack work first, then deeper systems projects—each row is built to show what I can deliver on a team.
					</p>
					<div class="grid md:grid-cols-2 grid-flow-row gap-8 w-full max-w-5xl">
						{projects.map((project) => (
							<ProjectCard
								src={project.src}
								title={project.title}
								body={project.body}
								href={project.href}
								demoUrl={project.demoUrl}
								techs={project.techs}
								buttonText={project.buttonText}
								projectPage={project.projectPage}
							/>
						))}
					</div>
				</section>

				<section class="flex w-full max-w-3xl flex-col gap-6 mt-20 px-4">
					<h2 class="text-2xl font-bold text-center">What I’m strongest at</h2>
					<div class="grid gap-6 sm:grid-cols-2 text-left">
						<div class="rounded-lg border border-border bg-card p-5 shadow-sm">
							<h3 class="font-semibold text-foreground mb-2">What I build</h3>
							<p class="text-sm text-muted-foreground">
								Full-stack web apps, internal tools, AI-assisted CLIs and extensions, and backend services—owned end-to-end from requirements to deployment.
							</p>
						</div>
						<div class="rounded-lg border border-border bg-card p-5 shadow-sm">
							<h3 class="font-semibold text-foreground mb-2">Core stack</h3>
							<ul class="text-sm text-muted-foreground space-y-2 list-disc pl-4">
								<li><span class="text-foreground font-medium">Frontend:</span> React, Remix, TypeScript, Tailwind</li>
								<li><span class="text-foreground font-medium">Backend:</span> Node.js, Go, REST APIs</li>
								<li><span class="text-foreground font-medium">Databases:</span> PostgreSQL, MySQL, MongoDB</li>
								<li><span class="text-foreground font-medium">AI / automation:</span> Gemini API, LLM integrations, CLI tooling</li>
								<li><span class="text-foreground font-medium">Systems:</span> Rust, C, networking, DNS, HTTP, Linux</li>
							</ul>
						</div>
						<div class="rounded-lg border border-border bg-card p-5 shadow-sm sm:col-span-2">
							<h3 class="font-semibold text-foreground mb-2">Roles I’m looking for</h3>
							<p class="text-sm text-muted-foreground">
								Full-stack or backend-leaning product engineering (TypeScript/React/Node or Go), platform or developer-tools teams, and teams shipping AI features where reliability and UX both matter.
							</p>
						</div>
					</div>
				</section>

				<section class="flex w-full flex-col items-center gap-6 mt-20 px-4">
					<h2 class="text-2xl font-bold">Engineering notes</h2>
					<p class="text-center text-muted-foreground max-w-xl">
						Long-form posts that mirror how I work: systems detail, full-stack integration, and clear explanations.
					</p>
					<ul class="flex flex-col gap-4 w-full max-w-2xl">
						{engineeringNotes.map((post) => (
							<li>
								<a
									href={post.href}
									class="block rounded-lg border border-border bg-card p-5 shadow-sm transition-all hover:shadow-md hover:border-primary/30"
								>
									<span class="font-semibold text-foreground">{post.title}</span>
									<p class="text-sm text-muted-foreground mt-2 mb-0">{post.description}</p>
								</a>
							</li>
						))}
					</ul>
					<a href="/blog" class="uk-button uk-button-default"> All posts </a>
				</section>

				<section class="flex flex-col items-center gap-8 mt-20 px-4">
					<h2 class="text-2xl font-bold">Get in touch</h2>
					<p class="text-center text-muted-foreground">
						Open to full-time roles and serious collaborations—tell me what you’re building.
					</p>
					<a class="uk-button uk-button-primary gap-x-2" href="mailto:contact@bernoussama.com" target="_blank">
						Contact me
					</a>
				</section>
			</div>
		</div>
	</main>
</Layout>
