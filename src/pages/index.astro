---
import Layout from '../layouts/Layout.astro';
import { featuredProjects } from '../data/projects';

const featuredWriting = [
	{
		url: '/blog/go-embed',
		title: 'How to Seamlessly Embed a Remix SPA into Your Go Backend',
		description: 'Embedding a Remix SPA into a Go backend for a simpler full-stack deployment model.',
		pubDate: '2025-01-28',
	},
	{
		url: '/blog/rust-http-server-1',
		title: 'Rewriting a C HTTP Server in Rust from Scratch, Part 1',
		description: 'Rebuilding a C HTTP server in Rust to improve safety and maintainability.',
		pubDate: '2025-03-09',
	},
	{
		url: '/blog/web-request-journey',
		title: 'The Journey of an HTTP Request',
		description: 'What happens between entering a URL and loading a web page?',
	},
];

const primaryProjects = featuredProjects.slice(0, 2);
const secondaryProjects = featuredProjects.slice(2, 5);
---

<Layout>
	<main class="grid grid-cols-12 min-h-screen bg-surface">
		<section class="col-span-12 lg:col-span-8 p-8 md:p-16 lg:p-24 flex flex-col justify-center grid-border-r">
			<div class="mb-8">
				<p class="text-primary font-mono text-xs uppercase tracking-[0.3em] mb-4">High Performance Software Systems</p>
				<h1 class="text-6xl md:text-8xl lg:text-9xl font-black leading-[0.9] tracking-tight-display uppercase max-w-4xl">
					Product<br />Engineering.
				</h1>
			</div>
			<p class="text-lg md:text-xl text-on-surface-variant max-w-2xl leading-relaxed">
				Building end-to-end software across React, TypeScript, Node.js, Go, and Rust. Direct, efficient, and focused on product systems that ship cleanly.
			</p>
		</section>
		<aside class="col-span-12 lg:col-span-4 flex flex-col">
			<div class="flex-grow p-8 md:p-12 flex flex-col justify-end grid-border-b">
				<div class="font-mono text-[10px] text-on-surface-variant/60 space-y-1 uppercase tracking-wider">
					<p>Status: Open to opportunities</p>
					<p>Focus: Product / Systems / AI Tooling</p>
					<p>Stack: TypeScript / Go / Rust</p>
				</div>
			</div>
			<a class="p-8 md:p-12 group hover:bg-surface-high transition-colors" href="/projects">
				<div class="mb-4">
					<svg class="w-8 h-8 transform group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
					</svg>
				</div>
				<span class="text-2xl font-black uppercase tracking-tight block">View Portfolio</span>
			</a>
		</aside>
	</main>

	<section class="grid grid-cols-12 grid-border-t grid-border-b">
		<div class="col-span-12 lg:col-span-6 grid-border-r overflow-hidden h-[360px] md:h-[500px] bg-surface-lowest">
			<img
				src="/images/simplinvo-landing.webp"
				alt="Simplinvo interface"
				class="w-full h-full object-cover opacity-60 grayscale hover:grayscale-0 transition-all duration-700"
				loading="lazy"
			/>
		</div>
		<div class="col-span-12 lg:col-span-6 p-8 md:p-12 flex items-center justify-center bg-surface-lowest">
			<div class="w-full max-w-2xl terminal-block">
				<span class="text-primary mr-2">$</span>
				<span>build product --stack react,node,go,rust --mode direct</span>
			</div>
		</div>
	</section>

	<section class="grid grid-cols-1 lg:grid-cols-2 grid-border-b">
		{primaryProjects.map((project, index) => (
			<article class={`p-8 md:p-12 relative group hover:bg-surface-high transition-colors ${index === 0 ? 'lg:grid-border-r' : ''} grid-border-b lg:border-b-0`}>
				<span class="absolute top-8 right-8 font-mono text-[10px] text-on-surface-variant/40 border border-outline-variant/20 px-2 py-0.5">0{index + 1}</span>
				<h3 class="text-3xl font-black uppercase tracking-tight-display mb-6">{project.title}</h3>
				<p class="text-on-surface-variant mb-8 max-w-md leading-relaxed">{project.body}</p>
				<div class="flex flex-wrap gap-3 mb-8">
					{project.techs.slice(0, 4).map((tech) => (
						<span class="font-mono text-[9px] border border-outline-variant/30 px-2 py-1 uppercase tracking-[0.15em] text-on-surface-variant/60">{tech}</span>
					))}
				</div>
				{project.actions && project.actions.length > 0 && (
					<div class="flex flex-wrap gap-3">
						{project.actions.slice(0, 2).map((action) => (
							<a
								href={action.href}
								target={action.external ? '_blank' : undefined}
								rel={action.external ? 'noreferrer' : undefined}
								class={action.variant === 'default'
									? 'border border-primary/40 text-primary font-mono text-[10px] uppercase tracking-widest px-4 py-2 hover:bg-primary hover:text-on-primary transition-colors'
									: 'bg-primary text-on-primary font-mono text-[10px] uppercase tracking-widest px-4 py-2 hover:bg-primary-dim transition-colors'}
							>
								{action.label}
							</a>
						))}
					</div>
				)}
			</article>
		))}
	</section>

	<section class="grid grid-cols-12 grid-border-b">
		{secondaryProjects.map((project, index) => (
			<article class={`col-span-12 lg:col-span-4 p-8 md:p-12 relative flex flex-col justify-between min-h-[320px] ${index < secondaryProjects.length - 1 ? 'lg:grid-border-r' : ''} grid-border-b lg:border-b-0 ${index === 1 ? 'bg-surface-low' : ''}`}>
				<div>
					<p class="font-mono text-[10px] uppercase tracking-[0.18em] text-on-surface-variant/50 mb-4">0{index + 3}</p>
					<h3 class="text-2xl font-black uppercase tracking-tight-display mb-6">{project.title}</h3>
					<p class="text-on-surface-variant text-sm leading-relaxed mb-8">
						{project.body}
					</p>
				</div>
				<div>
					{project.statusLabel ? (
						<span class="font-mono text-[10px] uppercase tracking-[0.18em] text-on-surface-variant/50">{project.statusLabel}</span>
					) : project.actions?.[0] ? (
						<a
							href={project.actions[0].href}
							target={project.actions[0].external ? '_blank' : undefined}
							rel={project.actions[0].external ? 'noreferrer' : undefined}
							class="font-mono text-[10px] uppercase tracking-[0.2em] underline underline-offset-8 decoration-primary hover:text-primary transition-colors"
						>
							{project.actions[0].label}
						</a>
					) : null}
				</div>
			</article>
		))}
	</section>

	<section class="p-8 md:p-16 lg:p-24 grid grid-cols-12 items-end grid-border-b">
		<div class="col-span-12 md:col-span-9">
			<h2 class="text-5xl md:text-8xl font-black uppercase tracking-tight-display leading-none">
				Selected<br />Writing
			</h2>
		</div>
		<div class="col-span-12 md:col-span-3 flex md:justify-end mt-6 md:mt-0">
			<a href="/blog" class="bg-primary hover:bg-primary-dim text-on-primary font-bold py-4 px-10 text-xs uppercase tracking-widest transition-colors inline-block">
				Read the Blog
			</a>
		</div>
	</section>

	<section class="grid grid-cols-1 grid-border-b">
		{featuredWriting.map((post) => (
			<a href={post.url} class="p-6 md:p-8 grid-border-b last:border-b-0 hover:bg-surface-high transition-colors group">
				<div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
					<div>
						<h3 class="text-xl font-bold tracking-tight group-hover:text-primary transition-colors">{post.title}</h3>
						<p class="mt-2 text-sm text-on-surface-variant max-w-3xl">{post.description}</p>
					</div>
					{post.pubDate && <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-on-surface-variant/50">{post.pubDate}</span>}
				</div>
			</a>
		))}
	</section>
</Layout>
