---
import Layout from '../layouts/Layout.astro';
import HeroBackground from '../components/HeroBackground.astro';
import ProjectCard from '../components/ProjectCard.astro';
import BlogPost from '../components/BlogPost.astro';
import TechBadge from '../components/TechBadge.astro';
import { featuredProjects } from '../data/projects';

const strengthGroups = [
	{
		title: "Full-stack product development",
		description: "Building user-facing features, backend logic, and data flows as one product surface instead of treating them as separate tracks.",
		items: ['TypeScript', 'React', 'Node.js', 'Remix', 'Tailwind'],
	},
	{
		title: 'AI integrations and workflow tooling',
		description: 'Using LLM APIs and automation patterns to make developer and team workflows faster, safer, and easier to use.',
		items: ['LLM Integrations', 'Gemini API', 'CLI Tooling', 'Automation'],
	},
	{
		title: 'Backend and systems engineering',
		description: 'Building APIs and low-level services with enough systems depth to reason about networking, performance, and reliability under the hood.',
		items: ['Go', 'Rust', 'Hono', 'REST APIs', 'Linux'],
	},
	{
		title: 'Data and platform fundamentals',
		description: 'Working comfortably with application data, deployment-minded architectures, and the operational details behind shipped software.',
		items: ['PostgreSQL', 'MySQL', 'MongoDB', 'PocketBase'],
	},
];

const featuredWriting = [
	{
		url: '/blog/go-embed',
		title: 'How to Seamlessly Embed a Remix SPA into Your Go Backend',
		description: 'Embedding a Remix SPA into a Go backend for a simpler full-stack deployment model.',
		pubDate: '2025-01-28',
	},
	{
		url: '/blog/rust-http-server-1',
		title: 'Rewriting a C HTTP Server in Rust from Scratch, Part 1',
		description: 'Rebuilding a C HTTP server in Rust to improve safety and maintainability.',
		pubDate: '2025-03-09',
	},
	{
		url: '/blog/web-request-journey',
		title: 'The Journey of an HTTP Request',
		description: 'What happens between entering a URL and loading a web page?',
	},
];
---

<Layout>
	<!-- Hero Section -->
	<main class="grid grid-cols-12 min-h-[80vh] relative">
		<HeroBackground />
		<section class="col-span-12 md:col-span-8 p-8 md:p-16 lg:p-24 flex flex-col justify-center relative z-10">
			<h2 class="text-primary font-mono text-xs uppercase tracking-[0.3em] mb-4">Full-Stack Engineer</h2>
			<h1 class="text-5xl md:text-7xl lg:text-8xl font-black leading-[0.9] tracking-tight-display uppercase max-w-3xl">
				Product Eng.<br/>AI Tooling.<br/>Systems.
			</h1>
			<p class="text-lg md:text-xl text-on-surface-variant max-w-xl leading-relaxed mt-6">
				Building end-to-end software across React, TypeScript, Node.js, Go, and Rust. From user-facing features and APIs to developer tooling, automation, and systems-heavy projects.
			</p>
		</section>
		<aside class="col-span-12 md:col-span-4 flex flex-col relative z-10 grid-border-t md:border-t-0 md:grid-border-l">
			<div class="flex-grow p-8 md:p-12 flex flex-col justify-end grid-border-b">
				<div class="font-mono text-[10px] text-on-surface-variant/60 space-y-1 uppercase tracking-wider">
					<p>Status: Open to opportunities</p>
					<p>Focus: Product + Systems</p>
					<p>Stack: TS / Go / Rust</p>
				</div>
			</div>
			<a class="p-8 md:p-12 group hover:bg-surface-high transition-all duration-300" href="/projects">
				<div class="mb-4">
					<svg class="w-8 h-8 transform group-hover:translate-x-2 transition-transform text-on-surface-variant group-hover:text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
					</svg>
				</div>
				<span class="text-2xl font-black uppercase tracking-tight block">View Projects</span>
			</a>
		</aside>
	</main>

	<!-- Secondary Grid -->
	<section class="grid grid-cols-12 grid-border-t grid-border-b">
		<div class="col-span-12 lg:col-span-7 grid-border-b lg:grid-border-b-0 lg:grid-border-r overflow-hidden h-[320px] md:h-[420px] bg-surface-lowest">
			<img
				src="/images/simplinvo-landing.webp"
				alt="Simplinvo product interface"
				class="w-full h-full object-cover opacity-65 grayscale hover:grayscale-0 transition-all duration-700"
				loading="lazy"
			/>
		</div>
		<div class="col-span-12 lg:col-span-5 p-8 md:p-12 flex items-center bg-surface-lowest">
			<div class="w-full space-y-8">
				<div>
					<p class="label-md text-primary mb-4">Technical Readout</p>
					<h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight-display leading-[0.95]">
						High-signal software with product discipline.
					</h2>
				</div>
				<div class="terminal-block">
					<span class="text-primary mr-2">$</span>
					<span>build product --stack "react,node,go,rust" --focus "clarity, throughput, ownership"</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Strengths Section -->
	<section class="grid-border-b">
		<div class="p-8 md:p-16">
			<div class="flex flex-col gap-2 mb-10">
				<h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight-display">Core Strengths</h2>
				<p class="text-on-surface-variant max-w-xl">My strongest work sits where product engineering, practical AI workflows, and backend depth overlap.</p>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-0 grid-border-t grid-border-l">
				{strengthGroups.map((group) => (
					<div class="p-6 md:p-8 grid-border-r grid-border-b hover:bg-surface-high transition-colors">
						<h3 class="text-lg font-bold tracking-tight mb-3">{group.title}</h3>
						<p class="text-sm text-on-surface-variant mb-5 leading-relaxed">{group.description}</p>
						<div class="flex flex-wrap gap-2">
							{group.items.map((item) => <TechBadge name={item} />)}
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Featured Projects Section -->
	<section class="grid-border-b">
		<div class="p-8 md:p-16">
			<div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10">
				<div>
					<h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight-display">Featured Projects</h2>
					<p class="text-on-surface-variant mt-2 max-w-xl">Selected work that shows product thinking, technical range, and end-to-end ownership.</p>
				</div>
				<a href="/projects" class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary hover:text-primary-dim transition-colors border border-primary/40 px-4 py-2">See All</a>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-0 grid-border-t grid-border-l">
				{featuredProjects.map((project, i) => (
					<ProjectCard
						src={project.src}
						title={project.title}
						body={project.body}
						techs={project.techs}
						projectPage={project.projectPage}
						actions={project.actions}
						statusLabel={project.statusLabel}
						index={i}
					/>
				))}
			</div>
		</div>
	</section>

	<!-- Writing Section -->
	<section class="grid-border-b">
		<div class="p-8 md:p-16">
			<div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10">
				<div>
					<h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight-display">Selected Writing</h2>
					<p class="text-on-surface-variant mt-2 max-w-xl">Writing that shows how I think through systems, tradeoffs, and implementation details.</p>
				</div>
				<a href="/blog" class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary hover:text-primary-dim transition-colors border border-primary/40 px-4 py-2">Read More</a>
			</div>
			<div class="grid-border-t">
				{featuredWriting.map((post) => (
					<BlogPost url={post.url} title={post.title} description={post.description} pubDate={post.pubDate} />
				))}
			</div>
		</div>
	</section>

	<!-- CTA Section -->
	<section class="p-8 md:p-16 lg:p-24 grid grid-cols-12 items-end grid-border-b">
		<div class="col-span-12 md:col-span-9">
			<h2 class="text-5xl md:text-7xl font-black uppercase tracking-tight-display leading-none">
				Let's build<br/>something useful.
			</h2>
		</div>
		<div class="col-span-12 md:col-span-3 flex md:justify-end mt-6 md:mt-0">
			<a href="mailto:contact@bernoussama.com" class="bg-primary hover:bg-primary-dim text-on-primary font-bold py-4 px-10 text-xs uppercase tracking-widest transition-all inline-block">
				Get in Touch
			</a>
		</div>
	</section>
</Layout>
