---
import Layout from '../../layouts/Layout.astro';
import TechBadge from '../../components/TechBadge.astro';

const project = {
  title: "DNS Server",
  description: "From-scratch DNS server that moves from Python prototyping to a lower-level Go implementation to exercise protocol parsing, resolution flow, and packet handling.",
  problem: "DNS is foundational to networked systems, but most application work hides it behind libraries and infrastructure. This project goes down a layer to implement record parsing, resolution logic, and server behavior directly.",
  features: ["DNS message parsing and serialization",
    "Recursive and iterative resolution paths",
    "Support for common record types",
    "Caching to reduce repeated upstream lookups",
    "Python prototype to validate behavior before the Go implementation",
    "Modular structure for extending records and resolver logic"],
  techStack: ["Python", "Go", "DNS", "Networking", "Protocols", "Bit Manipulation"],
  githubUrl: "https://github.com/bernoussama/mercury",
  images: ["/images/dns-image.webp"]
};
---

<Layout>
  <section class="grid-border-b">
    <div class="p-8 md:p-16">
      <a href="/projects" class="font-mono text-[10px] uppercase tracking-[0.2em] text-on-surface-variant hover:text-primary transition-colors inline-flex items-center gap-2 mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Back to Projects
      </a>
      <h1 class="text-4xl md:text-6xl font-black uppercase tracking-tight-display leading-none">{project.title}</h1>
      <p class="mt-4 text-lg text-on-surface-variant max-w-2xl">{project.description}</p>
    </div>
  </section>

  <section class="grid-border-b">
    <div class="grid grid-cols-1 lg:grid-cols-3">
      <div class="lg:col-span-2 p-8 md:p-12 grid-border-r grid-border-b lg:border-b-0">
        <h2 class="text-2xl font-black uppercase tracking-tight-display mb-4">The Problem</h2>
        <p class="text-on-surface-variant leading-relaxed">{project.problem}</p>
        
        <h2 class="text-2xl font-black uppercase tracking-tight-display mt-8 mb-4">Solution</h2>
        <ul class="space-y-2 text-on-surface-variant">
          {project.features.map((feature) => (
            <li class="flex gap-3"><span class="mt-2 h-1.5 w-1.5 flex-none bg-primary"></span><span>{feature}</span></li>
          ))}
        </ul>
      </div>
      <div class="p-8 md:p-12">
        <h3 class="font-mono text-[10px] uppercase tracking-[0.2em] text-on-surface-variant/60 mb-4">Tech Stack</h3>
        <div class="flex flex-wrap gap-2">
          {project.techStack.map((tech) => <TechBadge name={tech} />)}
        </div>
        <div class="mt-8">
          <a href={project.githubUrl} target="_blank" rel="noreferrer" class="border border-primary/40 text-primary font-bold text-xs uppercase tracking-widest px-6 py-3 hover:bg-primary hover:text-on-primary transition-colors inline-block">View on GitHub</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
