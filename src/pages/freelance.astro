---
import Layout from '../layouts/Layout.astro';
import HeroBackground from '../components/HeroBackground.astro';
import ProjectCard from '../components/ProjectCard.astro';

const services = [
  {
    title: 'Scoping',
    desc: 'Start by clarifying the problem, constraints, and what a successful delivery should look like.',
  },
  {
    title: 'Plan',
    desc: 'Turn the scope into a concrete implementation plan with milestones, tradeoffs, and deliverables.',
  },
  {
    title: 'Build',
    desc: 'Deliver iteratively with regular updates, working software, and room for feedback as the project takes shape.',
  },
  {
    title: 'Ship & Support',
    desc: 'Handle launch cleanly and stay available for follow-up improvements, fixes, or handoff support.',
  },
];

const samples = [
  {
    src: 'images/desktop-preview.webp',
    title: 'Fylo - Responsive Landing Page',
    body: 'A fully responsive landing page for a SaaS product.',
    href: 'https://github.com/bernoussama/fylo-landing-page',
    demoUrl: 'https://fylo.oussamabernou.me/',
    techs: ['HTML', 'CSS']
  },
  {
    src: 'images/Source-project.webp',
    title: 'Source - Responsive Template',
    body: 'A multipurpose responsive landing page template.',
    href: 'https://github.com/bernoussama/source-layout',
    demoUrl: 'https://source-layout.oussamabernou.me/',
    techs: ['HTML', 'CSS']
  },
  {
    src: 'images/random-user.gif',
    title: 'Random User Generator',
    body: 'Fetches and displays random user data with a clean UI.',
    href: '#',
    demoUrl: 'https://random-user.oussamabernou.me/',
    techs: ['HTML', 'CSS', 'JS']
  },
  {
    src: 'images/grocery.gif',
    title: 'Mobile Grocery List',
    body: 'A simple mobile-friendly grocery list with local storage.',
    href: 'https://github.com/bernoussama/grocery-list',
    demoUrl: 'https://grocery-list.oussamabernou.me/',
    techs: ['HTML', 'CSS', 'JS']
  },
];
---

<Layout>
  <main class="container">
    <div class="mx-auto max-w-7xl">
      <div class="relative w-full px-4 py-10 md:py-14 lg:py-20">
        <HeroBackground />
        <div class="relative z-10 flex flex-col items-center gap-3">
          <h1 class="text-center text-3xl font-bold leading-tight tracking-tight md:text-5xl lg:leading-[1.1]">
            Selective Consulting and Contract Work
          </h1>
          <p class="text-center text-lg sm:text-xl max-w-[680px] text-neutral-600">
            I occasionally take on short-term product engineering, AI workflow, and backend-heavy consulting work alongside my core full-time search.
          </p>
          <div class="flex w-full items-center justify-center space-x-4 py-4">
            <a class="uk-button uk-button-primary gap-x-2" href="mailto:contact@bernoussama.com" target="_blank">Contact Me</a>
            <a class="uk-button uk-button-default gap-x-2" href="/blog">Blog</a>
          </div>
        </div>
      </div>

      <section class="flex flex-col items-center gap-8 mt-6">
        <h2 class="text-2xl font-bold">How I Work</h2>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4 w-full">
          {services.map((s, idx) => (
            <div class="rounded-lg border border-neutral-200/60 bg-default p-6 shadow-sm">
              <div class="text-sm mb-2 text-neutral-500">Step {idx + 1}</div>
              <h3 class="text-lg font-semibold mb-2">{s.title}</h3>
              <p class="text-neutral-600">{s.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="flex flex-col items-center gap-8 mt-16">
        <h2 class="text-2xl font-bold">Selected Work Samples</h2>
        <div class="grid md:grid-cols-2 grid-flow-row gap-8 w-full">
          {samples.map((p) => (
            <ProjectCard src={p.src} title={p.title} body={p.body} href={p.href} demoUrl={p.demoUrl} techs={p.techs} />
          ))}
        </div>
      </section>

      <section class="flex flex-col items-center gap-6 mt-16">
        <h2 class="text-2xl font-bold">Interested in Working Together?</h2>
        <p class="text-center text-md sm:text-lg max-w-[680px] text-neutral-600">
          If you need help shipping a product feature, building an internal tool, or tightening up a backend workflow, feel free to reach out.
        </p>
        <a class="uk-button uk-button-primary gap-x-2" href="mailto:contact@bernoussama.com" target="_blank">Get in touch</a>
      </section>
    </div>
  </main>
</Layout>
