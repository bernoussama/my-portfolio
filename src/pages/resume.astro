---
import Layout from '../layouts/Layout.astro';
import { featuredProjects } from '../data/projects';

const coreStrengths = [
  'Full-stack product development across TypeScript, React, Node.js, and Go',
  'Practical AI integrations and workflow tooling for developer productivity',
  'Backend and systems work across APIs, networking, and low-level services',
  'Ownership from user-facing product work through data flow and deployment-minded implementation',
];

const coreStack = [
  { category: 'Frontend', items: 'TypeScript, React, Remix, Tailwind' },
  { category: 'Backend', items: 'Node.js, Go, Hono, REST APIs, automation tooling' },
  { category: 'Systems', items: 'Rust, C, Linux, networking, DNS, HTTP' },
];

const selectedWriting = [
  { title: 'How to Seamlessly Embed a Remix SPA into Your Go Backend', href: '/blog/go-embed' },
  { title: 'Rewriting a C HTTP Server in Rust from Scratch, Part 1', href: '/blog/rust-http-server-1' },
  { title: 'The Journey of an HTTP Request', href: '/blog/web-request-journey' },
];
---

<Layout>
  <section class="grid-border-b">
    <div class="p-8 md:p-16">
      <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-on-surface-variant mb-6">Resume</p>
      <h1 class="text-5xl md:text-7xl font-black uppercase tracking-tight-display leading-none">Oussama Bernou</h1>
      <p class="mt-4 text-xl text-on-surface-variant max-w-2xl">Full-stack engineer focused on product engineering, AI-powered tooling, and backend systems.</p>
      <p class="mt-4 text-on-surface-variant max-w-2xl">
        I build end-to-end software across frontend, backend, and systems-heavy work, with particular strength in product engineering, developer tooling, and practical AI integrations.
      </p>
      <div class="mt-6 flex flex-wrap gap-4">
        <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-on-surface-variant">
          hello@bernoussama.com
        </span>
        <a href="https://github.com/bernoussama" target="_blank" rel="noreferrer" class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary hover:text-primary-dim transition-colors">github.com/bernoussama</a>
        <a href="https://linkedin.com/in/oussama-bernou" target="_blank" rel="noreferrer" class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary hover:text-primary-dim transition-colors">linkedin.com/in/oussama-bernou</a>
      </div>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="mailto:hello@bernoussama.com" class="bg-primary hover:bg-primary-dim text-on-primary font-bold text-xs uppercase tracking-widest px-6 py-3 transition-colors">Contact</a>
        <a href="/projects" class="border border-primary/40 text-primary font-bold text-xs uppercase tracking-widest px-6 py-3 hover:bg-primary hover:text-on-primary transition-colors">View Projects</a>
      </div>
    </div>
  </section>

  <section class="grid grid-cols-1 lg:grid-cols-2 grid-border-b">
    <div class="p-8 md:p-12 grid-border-r grid-border-b lg:border-b-0">
      <h2 class="text-2xl font-black uppercase tracking-tight-display mb-6">Core Strengths</h2>
      <ul class="space-y-4">
        {coreStrengths.map((strength) => (
          <li class="flex gap-3 text-on-surface-variant">
            <span class="mt-2 h-2 w-2 flex-none bg-primary"></span>
            <span>{strength}</span>
          </li>
        ))}
      </ul>
    </div>
    <div class="p-8 md:p-12">
      <h2 class="text-2xl font-black uppercase tracking-tight-display mb-6">Core Stack</h2>
      <div class="space-y-4">
        {coreStack.map((stack) => (
          <div class="grid-border-b pb-4 last:border-0">
            <p class="font-bold text-sm">{stack.category}</p>
            <p class="text-sm text-on-surface-variant">{stack.items}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="grid-border-b">
    <div class="p-8 md:p-12">
      <div class="flex items-end justify-between gap-4 mb-8">
        <h2 class="text-2xl font-black uppercase tracking-tight-display">Selected Projects</h2>
        <a href="/projects" class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary hover:text-primary-dim transition-colors">See all</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0 grid-border-t grid-border-l">
        {featuredProjects.slice(0, 4).map((project) => (
          <div class="p-6 grid-border-r grid-border-b hover:bg-surface-high transition-colors">
            <h3 class="text-lg font-bold tracking-tight">{project.title}</h3>
            {project.statusLabel && <span class="font-mono text-[9px] uppercase tracking-wider text-on-surface-variant/60">{project.statusLabel}</span>}
            <p class="mt-2 text-sm text-on-surface-variant">{project.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="grid-border-b">
    <div class="p-8 md:p-12">
      <div class="flex items-end justify-between gap-4 mb-8">
        <h2 class="text-2xl font-black uppercase tracking-tight-display">Selected Writing</h2>
        <a href="/blog" class="font-mono text-[10px] uppercase tracking-[0.2em] text-primary hover:text-primary-dim transition-colors">Read the blog</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-0 grid-border-t grid-border-l">
        {selectedWriting.map((post) => (
          <a href={post.href} class="p-6 grid-border-r grid-border-b hover:bg-surface-high transition-colors">
            <h3 class="text-sm font-bold tracking-tight">{post.title}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
