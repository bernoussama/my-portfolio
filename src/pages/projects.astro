---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { allProjects } from '../data/projects';
---

<Layout title="All Projects">
  <main class="container">
    <div class="mx-auto max-w-7xl px-4 py-8">
      <div class="mb-8">
        <a href="/" class="inline-flex items-center text-primary hover:opacity-80 transition-opacity">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1">
            <path d="m15 18-6-6 6-6"/>
          </svg>
          Back to Home
        </a>
      </div>
      
      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-foreground mb-4">My Projects</h1>
        <p class="text-muted-foreground max-w-2xl mx-auto text-lg">
	          A selection of product, AI, and systems work that shows how I build software across the stack.
        </p>
      </div>
      
      <section class="mb-12">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
	          {allProjects.map((project) => (
            <ProjectCard 
              src={project.src}
              title={project.title}
              body={project.body}
              techs={project.techs}
              projectPage={project.projectPage}
	              actions={project.actions}
	              statusLabel={project.statusLabel}
            />
          ))}
        </div>
      </section>
    </div>
  </main>
</Layout>
