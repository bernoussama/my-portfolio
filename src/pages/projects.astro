---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';
---

<Layout title="All Projects">
	<main class="container">
		<div class="mx-auto max-w-7xl px-4 py-8">
			<div class="mb-8">
				<a href="/" class="inline-flex items-center text-primary hover:opacity-80 transition-opacity">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1">
						<path d="m15 18-6-6 6-6" />
					</svg>
					Back to Home
				</a>
			</div>

			<div class="text-center mb-12">
				<h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-foreground mb-4">Projects</h1>
				<p class="text-muted-foreground max-w-2xl mx-auto text-lg">
					Full-stack and product work alongside systems and learning projects—ordered to highlight what is most relevant for hiring.
				</p>
			</div>

			<section class="mb-12">
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					{projects
						.filter((p) => p.title !== 'More projects…')
						.map((project) => (
							<ProjectCard
								src={project.src}
								title={project.title}
								body={project.body}
								href={project.href}
								demoUrl={project.demoUrl}
								techs={project.techs}
								buttonText={project.buttonText}
								projectPage={project.projectPage}
							/>
						))}
				</div>
			</section>
		</div>
	</main>
</Layout>
