---
import '../../style.css';
const { pathname } = Astro.url;
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>404 | Oussama Bernou</title>
		<link rel="preload" href="/fonts/inter/inter-latin-400.woff2" as="font" type="font/woff2" crossorigin />
	</head>
	<body class="bg-surface text-on-surface font-sans antialiased">
		<main class="min-h-screen grid grid-cols-12">
			<section class="col-span-12 md:col-span-8 p-8 md:p-16 lg:p-24 flex flex-col justify-center grid-border-r">
				<p class="label-md text-primary mb-4">404 / Routing Fault</p>
				<h1 class="text-6xl md:text-8xl font-black uppercase tracking-tight-display leading-[0.9]">
					Page Not<br />Found.
				</h1>
				<p class="mt-6 max-w-xl text-lg text-on-surface-variant leading-relaxed">
					The requested page does not exist or has moved to a different path.
				</p>
				<div class="mt-8 flex flex-wrap gap-3">
					<a href="/" class="bg-primary text-on-primary font-bold text-xs uppercase tracking-widest px-6 py-3 hover:bg-primary-dim">Return Home</a>
					<a href="/projects" class="border border-primary/40 text-primary font-bold text-xs uppercase tracking-widest px-6 py-3 hover:bg-primary hover:text-on-primary">View Projects</a>
				</div>
			</section>
			<aside class="col-span-12 md:col-span-4 flex flex-col">
				<div class="flex-grow p-8 md:p-12 flex flex-col justify-end grid-border-b md:grid-border-b-0">
				<div class="font-mono text-[10px] uppercase tracking-[0.18em] text-on-surface-variant space-y-2">
						<p>Status: Missing route</p>
						<p>Path: {pathname}</p>
					</div>
				</div>
				<div class="p-8 md:p-12 bg-surface-lowest border-l border-primary">
					<p class="font-mono text-sm text-on-surface-variant">
						<span class="text-primary mr-2">$</span>
						<span>resolve --path "{pathname}"</span>
					</p>
				</div>
			</aside>
		</main>
	</body>
</html>
